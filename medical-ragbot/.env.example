# ========================================
# MediVault RAG Bot - Environment Template
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ========================================

# ========== LLM (Groq) ==========
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1500
GROQ_API_KEY=your_groq_api_key_here

# Ollama (local alternative — set LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# ========== Embeddings ==========
USE_LOCAL_EMBEDDINGS=true
LOCAL_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768

# OpenAI embeddings (alternative — set USE_LOCAL_EMBEDDINGS=false)
OPENAI_API_KEY=your_openai_api_key_here

# ========== MongoDB Atlas ==========
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_DB_NAME=medivault
MONGODB_COLLECTION_NAME=medical_vectors
VECTOR_INDEX_NAME=vector_index

# ========== Chunking ==========
CHUNK_SIZE=600
CHUNK_OVERLAP_PERCENT=0.25
USE_SENTENCE_BOUNDARIES=true

# ========== Data Directories ==========
DATA_DIR=data
RAW_PDFS_DIR=data/raw_pdfs
PROCESSED_TEXT_DIR=data/processed_text

# ========== API ==========
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

# ========== OCR (Linux/Docker — leave blank, binaries are in PATH) ==========
# Windows only: set full paths to Tesseract and Poppler
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\poppler\poppler-24.08.0\Library\bin

# ========== Vector Search ==========
RETRIEVAL_MAX_TOKENS=3000
DEFAULT_RETRIEVAL_K=5
MULTI_STAGE_INITIAL_K=20
MAX_CONTEXT_LENGTH=3500

# ========== Versioning ==========
ENABLE_DOCUMENT_VERSIONING=true
DOCUMENT_VERSION=v1.0
