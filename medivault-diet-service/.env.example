# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Use the same Atlas cluster as the main MediVault backend
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=medivault_diet

# ─── JWT ──────────────────────────────────────────────────────────────────────
# MUST be identical to JWT_ACCESS_SECRET in the main MediVault backend
# This service validates patient JWTs issued by that backend
JWT_ACCESS_SECRET=<same-secret-as-main-backend>
JWT_ALGORITHM=HS256

# ─── MediVault Main Backend ───────────────────────────────────────────────────
# Used internally to fetch patient medical data
MEDIVAULT_API_BASE_URL=https://medivault-backend-0xjf.onrender.com/api/v1

# ─── LLM Provider API Keys ────────────────────────────────────────────────────
# Leave blank for any provider you don't have. The service will skip it.
# At least ONE key must be present or the service will refuse to start.
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── LLM Model Names ──────────────────────────────────────────────────────────
# Defaults are set in code — override here if needed
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-haiku-20240307
OPENAI_MODEL=gpt-4o-mini

# ─── LLM Fallback Order ───────────────────────────────────────────────────────
# Comma-separated. Providers with blank API keys are skipped automatically.
# At runtime, only configured providers are in the active chain.
LLM_FALLBACK_ORDER=groq,gemini,claude,openai

# ─── Session Config ───────────────────────────────────────────────────────────
SESSION_MAX_MESSAGES=100
SESSION_INACTIVITY_TIMEOUT_HOURS=24
MAX_CONTEXT_TOKENS=6000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_CHAT_PER_MINUTE=15

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081
